<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<style>
body{background:#111827;color:white;font-family:Arial;display:flex;justify-content:center;align-items:center;height:100vh;}
form{background:#1f2937;padding:40px;border-radius:12px;width:300px;}
input{width:100%;padding:10px;margin:10px 0;background:#374151;border:none;color:white;}
button{width:100%;padding:10px;background:#6366f1;border:none;color:white;}
</style>
</head>
<body>
<form method="POST">
<h2>Admin Login</h2>
<input name="username" placeholder="Username" required>
<input type="password" name="password" placeholder="Password" required>
<button>Login</button>
<p style="color:red;"><%= error %></p>
</form>
</body>
</html>