<script>
    // Theme Engine
    const savedTheme = localStorage.getItem('bloom_theme') || 'dark';
    document.documentElement.setAttribute('data-theme', savedTheme);
    function changeTheme(t) { 
        document.documentElement.setAttribute('data-theme', t); 
        localStorage.setItem('bloom_theme', t); 
    }

    // Improved Toggle Logic
    function toggleSidebar() {
        const body = document.body;
        const isCollapsed = body.classList.toggle('sidebar-collapsed');
        localStorage.setItem('sidebar_state', isCollapsed ? 'collapsed' : 'expanded');
    }

    // Apply state on load
    document.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('sidebar_state') === 'collapsed') {
            document.body.classList.add('sidebar-collapsed');
        }
    });
</script>

<style>
