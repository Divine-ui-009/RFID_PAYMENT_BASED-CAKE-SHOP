<!DOCTYPE html>
<html>
<head><title>Bakery OS | Inventory</title></head>
<body>
    <%- include('partials/nav') %>
    <div style="padding: 40px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h1 style="margin: 0;">Inventory & Stock</h1>
            <button onclick="document.getElementById('add-modal').style.display='flex'" style="background:var(--accent); color:white; border:none; padding:12px 25px; border-radius:10px; font-weight:700; cursor:pointer;">+ Add New Product</button>
        </div>

        <div style="background: var(--surface); border-radius: 15px; border: 1px solid var(--border); overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead style="background: rgba(0,0,0,0.05); border-bottom: 1px solid var(--border);">
                    <tr>
                        <th style="padding: 15px;">Item</th>
                        <th style="padding: 15px;">Price</th>
                        <th style="padding: 15px;">Stock</th>
                        <th style="padding: 15px; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(p => { %>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 15px;">
                                <form action="/products/update" method="POST" style="display:flex; align-items:center; gap:10px;" id="form-<%= p.id %>">
                                    <input type="hidden" name="id" value="<%= p.id %>">
                                    <span style="font-size: 1.5rem;"><%= p.icon %></span>
                                    <input type="text" name="name" value="<%= p.name %>" style="background:transparent; border:1px solid var(--border); color:var(--text); padding:5px; border-radius:5px;">
                            </td>
                            <td style="padding: 15px;">
                                    $<input type="number" step="0.01" name="price" value="<%= p.price %>" style="background:transparent; border:1px solid var(--border); color:var(--text); padding:5px; border-radius:5px; width:80px;">
                            </td>
                            <td style="padding: 15px;">
                                    <input type="number" name="stock" value="<%= p.stock %>" style="background:transparent; border:1px solid var(--border); color:var(--text); padding:5px; border-radius:5px; width:80px;">
                            </td>
                            <td style="padding: 15px; text-align: right; display: flex; justify-content: flex-end; gap: 10px;">
                                    <button type="submit" style="background:#10b981; color:white; border:none; padding:8px 15px; border-radius:5px; cursor:pointer;">Save</button>
                                </form>
                                <form action="/products/delete/<%= p.id %>" method="POST">
                                    <button type="submit" style="background:#ef4444; color:white; border:none; padding:8px 15px; border-radius:5px; cursor:pointer;">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="add-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:var(--surface); padding:40px; border-radius:20px; width:400px; border:1px solid var(--border);">
            <h2 style="margin-top:0;">Add New Product</h2>
            <form action="/products/add" method="POST">
                <label style="color:var(--text-muted); font-size:0.9rem;">Product Name</label>
                <input type="text" name="name" required style="width:100%; background:var(--bg); color:var(--text); border:1px solid var(--border); padding:12px; border-radius:8px; margin-bottom:15px; box-sizing:border-box;">
                
                <div style="display:flex; gap:10px; margin-bottom:15px;">
                    <div style="flex:1;">
                        <label style="color:var(--text-muted); font-size:0.9rem;">Price ($)</label>
                        <input type="number" step="0.01" name="price" required style="width:100%; background:var(--bg); color:var(--text); border:1px solid var(--border); padding:12px; border-radius:8px; box-sizing:border-box;">
                    </div>
                    <div style="flex:1;">
                        <label style="color:var(--text-muted); font-size:0.9rem;">Stock</label>
                        <input type="number" name="stock" required style="width:100%; background:var(--bg); color:var(--text); border:1px solid var(--border); padding:12px; border-radius:8px; box-sizing:border-box;">
                    </div>
                </div>

                <label style="color:var(--text-muted); font-size:0.9rem;">Emoji Icon</label>
                <input type="text" name="icon" placeholder="e.g. 🍪" required style="width:100%; background:var(--bg); color:var(--text); border:1px solid var(--border); padding:12px; border-radius:8px; margin-bottom:20px; box-sizing:border-box;">
                
                <button type="submit" style="width:100%; padding:12px; background:var(--accent); color:white; border:none; border-radius:8px; font-weight:bold; cursor:pointer;">Save Product</button>
                <button type="button" onclick="document.getElementById('add-modal').style.display='none'" style="width:100%; padding:12px; background:transparent; color:var(--text-muted); border:none; margin-top:10px; cursor:pointer;">Cancel</button>
            </form>
        </div>
    </div>
</body>
</html>